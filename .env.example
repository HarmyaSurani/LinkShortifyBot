# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=linkshortify

# ── LinkShortify API ──────────────────────────────────────────────────────────
LINKSHORTIFY_API_URL=https://linkshortify.com/api
LINKSHORTIFY_STATS_URL=https://linkshortify.com/stats

# ── Bot Configuration ─────────────────────────────────────────────────────────
# Channel users must join to use the bot (leave empty to disable)
CHANNEL_USERNAME=@yourchannel

# Comma-separated list of admin Telegram user IDs
ADMINS=123456789,987654321

# Contact shown in error/ban messages
OWNER_CONTACT=@YourSupport

# ── Logging Channels (optional, leave empty to disable) ───────────────────────
# Log every user action (commands, messages, signups)
USER_LOG_GROUP=@your_user_log_channel

# Log all exceptions with full tracebacks
ERROR_LOG_GROUP=@your_error_log_channel

# Log all admin actions (ban, unban, broadcast)
ADMIN_LOG_GROUP=@your_admin_log_channel

# ── Performance ───────────────────────────────────────────────────────────────
# Show "⏳ Processing..." messages (true/false)
PROCESSING_MESSAGE_ENABLED=true

# Number of users per batch during broadcast
BROADCAST_BATCH_SIZE=25
